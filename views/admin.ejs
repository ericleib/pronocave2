<%- include("partials/header", { title: "Admin" }) %>
<section class="page-title">
  <div>
    <p class="eyebrow">Administration</p>
    <h1><%= tournament.short_name %></h1>
  </div>
</section>

<section class="dashboard-grid">
  <form class="panel form-stack" method="post" action="<%= base %>/admin/phase">
    <h2>Phase</h2>
    <label><input type="radio" name="phase" value="0" <%= tournament.phase === 0 ? "checked" : "" %>> Pronos groupes ouverts</label>
    <label><input type="radio" name="phase" value="1" <%= tournament.phase === 1 ? "checked" : "" %>> Pronos finales ouverts</label>
    <label><input type="radio" name="phase" value="2" <%= tournament.phase === 2 ? "checked" : "" %>> Tout verrouillé</label>
    <button class="btn primary" type="submit"><i data-lucide="save"></i>Mettre à jour</button>
  </form>
  <form class="panel form-stack" method="post" action="<%= base %>/admin/active">
    <h2>Tournoi actif</h2>
    <select name="tournament_id">
      <% tournaments.forEach((item) => { %><option value="<%= item.id %>" <%= item.id === tournament.id ? "selected" : "" %>><%= item.name %></option><% }) %>
    </select>
    <button class="btn" type="submit"><i data-lucide="repeat"></i>Activer</button>
  </form>
  <form class="panel form-stack" method="post" action="<%= base %>/admin/users/rename" id="users">
    <h2>Joueurs</h2>
    <div class="admin-inline-form">
      <select name="user_id">
        <% users.forEach((user) => { %><option value="<%= user.id %>"><%= user.login %><%= user.banned ? " (désactivé)" : "" %></option><% }) %>
      </select>
      <input name="login" type="text" placeholder="Nouveau nom" required>
      <button class="btn" type="submit"><i data-lucide="check"></i>OK</button>
    </div>
    <div class="admin-user-list">
      <% users.forEach((user) => { %>
        <div class="admin-user-row">
          <span><%= user.login %><% if (user.banned) { %> <em>Désactivé</em><% } %></span>
          <form method="post" action="<%= base %>/admin/users/<%= user.id %>/ban">
            <input type="hidden" name="banned" value="<%= user.banned ? 0 : 1 %>">
            <button class="btn small <%= user.banned ? "" : "danger" %>" type="submit"><i data-lucide="<%= user.banned ? "undo-2" : "ban" %>"></i><%= user.banned ? "Réactiver" : "Désactiver" %></button>
          </form>
        </div>
      <% }) %>
    </div>
  </form>
  <section class="panel form-stack" id="maintenance">
    <h2>Maintenance</h2>
    <form method="post" action="<%= base %>/admin/bets/clear" class="confirm-form" data-confirm-title="Supprimer les pronos ?" data-confirm-text="Tous les pronos du tournoi <%= tournament.short_name %> seront supprimés. Les comptes et messages seront conservés.">
      <button class="btn danger" type="submit"><i data-lucide="trash-2"></i>Supprimer les pronos</button>
    </form>
    <form method="post" action="<%= base %>/admin/matches/reset" class="confirm-form" data-confirm-title="Réinitialiser les matchs ?" data-confirm-text="Tous les scores, statuts live/terminé, vainqueurs et équipes dérivées du tournoi <%= tournament.short_name %> seront remis à zéro. Les pronos seront conservés mais ne rapporteront plus de points.">
      <button class="btn danger" type="submit"><i data-lucide="rotate-ccw"></i>Réinitialiser les matchs</button>
    </form>
  </section>
</section>

<section class="panel" id="teams">
  <div class="panel-head"><h2>Équipes des finales</h2><span><%= matches.filter((m) => m.round !== "group").length %> matchs</span></div>
  <div class="match-list compact">
    <% matches.filter((match) => match.round !== "group").forEach((match) => { %>
      <div class="match-row admin-match-row">
        <div>
          <span class="tag"><%= match.round_label %></span>
          <strong><%= match.source_a_text %></strong>
          <span class="muted">vs</span>
          <strong><%= match.source_b_text %></strong>
          <small>Match <%= match.match_no %> · <%= match.kickoff_label %></small>
        </div>
        <div class="admin-team-picks">
          <form method="post" action="<%= base %>/admin/teams/<%= match.id %>/a" class="admin-result">
            <select name="team_id">
              <option value="">Équipe A</option>
              <% teams.forEach((team) => { %><option value="<%= team.id %>" <%= match.team_a_id === team.id ? "selected" : "" %>><%= team.group_code %> · <%= team.name %></option><% }) %>
            </select>
            <button class="btn small" type="submit"><i data-lucide="save"></i>A</button>
          </form>
          <form method="post" action="<%= base %>/admin/teams/<%= match.id %>/b" class="admin-result">
            <select name="team_id">
              <option value="">Équipe B</option>
              <% teams.forEach((team) => { %><option value="<%= team.id %>" <%= match.team_b_id === team.id ? "selected" : "" %>><%= team.group_code %> · <%= team.name %></option><% }) %>
            </select>
            <button class="btn small" type="submit"><i data-lucide="save"></i>B</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="panel" id="results">
  <div class="panel-head"><h2>Résultats</h2><span><%= matches.length %> matchs</span></div>
  <div class="match-list compact">
    <% matches.forEach((match) => { %>
      <div class="match-row admin-match-row">
        <div>
          <span class="tag"><%= match.round_label %></span>
          <strong><%= match.team_a_name || match.source_a_text %></strong>
          <span class="muted">vs</span>
          <strong><%= match.team_b_name || match.source_b_text %></strong>
          <small>Match <%= match.match_no %> · <%= match.kickoff_label %></small>
        </div>
        <form method="post" action="<%= base %>/admin/results/<%= match.id %>" class="admin-result">
          <select name="status">
            <option value="scheduled" <%= match.status === "scheduled" ? "selected" : "" %>>À venir</option>
            <option value="live" <%= match.status === "live" ? "selected" : "" %>>En cours</option>
            <option value="final" <%= match.status === "final" ? "selected" : "" %>>Terminé</option>
          </select>
          <select name="score_a"><% for (let i = 0; i <= 10; i++) { %><option value="<%= i %>" <%= match.score_a === i ? "selected" : "" %>><%= i %></option><% } %></select>
          <span>-</span>
          <select name="score_b"><% for (let i = 0; i <= 10; i++) { %><option value="<%= i %>" <%= match.score_b === i ? "selected" : "" %>><%= i %></option><% } %></select>
          <% if (match.round !== "group") { %>
            <select name="winner_team_id">
              <option value="">Vainqueur si nul</option>
              <% if (match.team_a_id) { %><option value="<%= match.team_a_id %>" <%= match.winner_team_id === match.team_a_id ? "selected" : "" %>><%= match.team_a_name %></option><% } %>
              <% if (match.team_b_id) { %><option value="<%= match.team_b_id %>" <%= match.winner_team_id === match.team_b_id ? "selected" : "" %>><%= match.team_b_name %></option><% } %>
            </select>
          <% } %>
          <button class="btn small" type="submit"><i data-lucide="check"></i>OK</button>
        </form>
        <% if (match.status !== "scheduled") { %>
          <form method="post" action="<%= base %>/admin/results/<%= match.id %>/clear"><button class="ghost danger" title="Annuler"><i data-lucide="x"></i></button></form>
        <% } %>
      </div>
    <% }) %>
  </div>
</section>
<dialog class="confirm-dialog" id="admin-confirm-dialog">
  <form method="dialog">
    <h2 id="confirm-title">Confirmer</h2>
    <p id="confirm-text"></p>
    <div class="inline-actions">
      <button class="btn" value="cancel">Annuler</button>
      <button class="btn danger" value="confirm">Confirmer</button>
    </div>
  </form>
</dialog>
<script>
  (() => {
    const dialog = document.querySelector("#admin-confirm-dialog");
    const title = document.querySelector("#confirm-title");
    const text = document.querySelector("#confirm-text");
    let pendingForm = null;
    for (const form of document.querySelectorAll(".confirm-form")) {
      form.addEventListener("submit", (event) => {
        if (form.dataset.confirmed === "true") return;
        event.preventDefault();
        pendingForm = form;
        title.textContent = form.dataset.confirmTitle || "Confirmer";
        text.textContent = form.dataset.confirmText || "";
        dialog.showModal();
      });
    }
    dialog.addEventListener("close", () => {
      if (dialog.returnValue !== "confirm" || !pendingForm) return;
      pendingForm.dataset.confirmed = "true";
      pendingForm.submit();
    });
  })();
</script>
<%- include("partials/footer") %>
