<%- include("partials/header", { title: "Admin" }) %>
<section class="page-title">
  <div>
    <p class="eyebrow">Administration</p>
    <h1><%= tournament.short_name %></h1>
  </div>
</section>

<section class="dashboard-grid">
  <form class="panel form-stack" method="post" action="<%= base %>/admin/phase">
    <h2>Phase</h2>
    <label><input type="radio" name="phase" value="0" <%= tournament.phase === 0 ? "checked" : "" %>> Pronos groupes ouverts</label>
    <label><input type="radio" name="phase" value="1" <%= tournament.phase === 1 ? "checked" : "" %>> Pronos finales ouverts</label>
    <label><input type="radio" name="phase" value="2" <%= tournament.phase === 2 ? "checked" : "" %>> Tout verrouillé</label>
    <button class="btn primary" type="submit"><i data-lucide="save"></i>Mettre à jour</button>
  </form>
  <form class="panel form-stack" method="post" action="<%= base %>/admin/active">
    <h2>Tournoi actif</h2>
    <select name="tournament_id">
      <% tournaments.forEach((item) => { %><option value="<%= item.id %>" <%= item.id === tournament.id ? "selected" : "" %>><%= item.name %></option><% }) %>
    </select>
    <button class="btn" type="submit"><i data-lucide="repeat"></i>Activer</button>
  </form>
</section>

<section class="panel" id="teams">
  <div class="panel-head"><h2>Équipes des finales</h2><span><%= matches.filter((m) => m.round !== "group").length %> matchs</span></div>
  <div class="match-list compact">
    <% matches.filter((match) => match.round !== "group").forEach((match) => { %>
      <div class="match-row">
        <div>
          <span class="tag"><%= match.round_label %></span>
          <strong><%= match.source_a_text %></strong>
          <span class="muted">vs</span>
          <strong><%= match.source_b_text %></strong>
          <small>Match <%= match.match_no %> · <%= match.kickoff_label %></small>
        </div>
        <div class="admin-team-picks">
          <form method="post" action="<%= base %>/admin/teams/<%= match.id %>/a" class="admin-result">
            <select name="team_id">
              <option value="">Équipe A</option>
              <% teams.forEach((team) => { %><option value="<%= team.id %>" <%= match.team_a_id === team.id ? "selected" : "" %>><%= team.group_code %> · <%= team.name %></option><% }) %>
            </select>
            <button class="btn small" type="submit"><i data-lucide="save"></i>A</button>
          </form>
          <form method="post" action="<%= base %>/admin/teams/<%= match.id %>/b" class="admin-result">
            <select name="team_id">
              <option value="">Équipe B</option>
              <% teams.forEach((team) => { %><option value="<%= team.id %>" <%= match.team_b_id === team.id ? "selected" : "" %>><%= team.group_code %> · <%= team.name %></option><% }) %>
            </select>
            <button class="btn small" type="submit"><i data-lucide="save"></i>B</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="panel" id="results">
  <div class="panel-head"><h2>Résultats</h2><span><%= matches.length %> matchs</span></div>
  <div class="match-list compact">
    <% matches.forEach((match) => { %>
      <div class="match-row">
        <div>
          <span class="tag"><%= match.round_label %></span>
          <strong><%= match.team_a_name || match.source_a_text %></strong>
          <span class="muted">vs</span>
          <strong><%= match.team_b_name || match.source_b_text %></strong>
          <small>Match <%= match.match_no %> · <%= match.kickoff_label %></small>
        </div>
        <form method="post" action="<%= base %>/admin/results/<%= match.id %>" class="admin-result">
          <select name="score_a"><% for (let i = 0; i <= 10; i++) { %><option value="<%= i %>" <%= match.score_a === i ? "selected" : "" %>><%= i %></option><% } %></select>
          <span>-</span>
          <select name="score_b"><% for (let i = 0; i <= 10; i++) { %><option value="<%= i %>" <%= match.score_b === i ? "selected" : "" %>><%= i %></option><% } %></select>
          <% if (match.round !== "group") { %>
            <select name="winner_team_id">
              <option value="">Vainqueur si nul</option>
              <% if (match.team_a_id) { %><option value="<%= match.team_a_id %>" <%= match.winner_team_id === match.team_a_id ? "selected" : "" %>><%= match.team_a_name %></option><% } %>
              <% if (match.team_b_id) { %><option value="<%= match.team_b_id %>" <%= match.winner_team_id === match.team_b_id ? "selected" : "" %>><%= match.team_b_name %></option><% } %>
            </select>
          <% } %>
          <button class="btn small" type="submit"><i data-lucide="check"></i>OK</button>
        </form>
        <% if (match.status === "final") { %>
          <form method="post" action="<%= base %>/admin/results/<%= match.id %>/clear"><button class="ghost danger" title="Annuler"><i data-lucide="x"></i></button></form>
        <% } %>
      </div>
    <% }) %>
  </div>
</section>
<%- include("partials/footer") %>
